function UI:HandleHackPC()
    if not self.hackPcActive then
        self.hackPcCurrent = nil
        return
    end

    local characterRoot = self:GetCharacterRoot()
    if not characterRoot then
        return
    end

    local current = self.hackPcCurrent
    local currentTrigger = current and current.trigger or nil
    local currentScreen = current and current.screen or nil

    if not currentTrigger or not currentTrigger.Parent or not self:IsHackableComputerScreen(currentScreen) then
        current = self:SelectRandomHackableComputer()
        currentTrigger = current and current.trigger or nil
        currentScreen = current and current.screen or nil
        if not currentTrigger then
            self.hackPcActive = false
            self:NotifyPlayer("No hackable computer found", "Windy", 3)
            return
        end
    end

    local targetPosition = currentTrigger.Position + Vector3.new(0, 2, 0)
    local distance = (targetPosition - characterRoot.Position).Magnitude

    if distance > 3 then
        pcall(function()
            characterRoot.CFrame = CFrame.new(targetPosition.X, targetPosition.Y, targetPosition.Z)
        end)
        return
    end

    local now = tick()
    if (now - (self.hackPcLastInteract or 0)) >= self.hackPcInteractInterval then
        self.hackPcLastInteract = now
        self:PressInteractKey()
    end
end

