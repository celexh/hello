    return character:FindFirstChild("HumanoidRootPart")
end

function UI:GetPlayerCharacterModel(player)
    if not player then
        return nil
    end

    local model = player.Character
    if not model or not model:IsDescendantOf(workspace) then
        model = workspace:FindFirstChild(player.Name)
    end

    if model and model:IsA("Model") then
        return model
    end

    return nil
end

function UI:IsBeastPlayer(player)
    if not player then
        return false
    end

    local ok, value = pcall(function()
        return player:GetAttribute("Beast")
    end)

    return ok and value == true or false
end

function UI:GetColorRGB(color)
    if not color then
        return nil, nil, nil
    end

    local rawR = tonumber(color.R) or 0
    local rawG = tonumber(color.G) or 0
    local rawB = tonumber(color.B) or 0

    local usesNormalizedRange = rawR <= 1 and rawG <= 1 and rawB <= 1
    local scale = usesNormalizedRange and 255 or 1

    local r = math.floor((rawR * scale) + 0.5)
    local g = math.floor((rawG * scale) + 0.5)
    local b = math.floor((rawB * scale) + 0.5)
    return r, g, b
end

function UI:IsHackableComputerScreen(screen)
    if not screen or not screen:IsA("BasePart") then
        return false
    end

    local r, g, b = self:GetColorRGB(screen.Color)
    return r == 13 and g == 105 and b == 172
end

function UI:GetComputerScreenFromTrigger(trigger)
    if not trigger or not trigger.Parent then
        return nil
    end

    local tableModel = trigger.Parent
    local directScreen = tableModel:FindFirstChild("Screen")
    if directScreen and directScreen:IsA("BasePart") then
        return directScreen
    end

    local otherFolder = tableModel:FindFirstChild("Other")
    if otherFolder then
        local otherScreen = otherFolder:FindFirstChild("Screen")
        if otherScreen and otherScreen:IsA("BasePart") then
            return otherScreen
        end
    end

    for _, descendant in ipairs(tableModel:GetDescendants()) do
        if descendant.Name == "Screen" and descendant:IsA("BasePart") then
            return descendant
        end
    end

    return nil
end

function UI:GetComputerEntries()
    local cached = self:RefreshComputerCache(false)
    local valid = {}

    for _, entry in ipairs(cached or {}) do
        local trigger = entry and entry.trigger or nil
        if trigger and trigger.Parent and trigger:IsDescendantOf(workspace) then
            table.insert(valid, entry)
        end
    end

    if #valid ~= #(cached or {}) then
        self.computerCache = valid
    end

    if #valid > 0 then
        return valid
    end

    return self:RefreshComputerCache(true)
end

function UI:GetComputerTargets()
    local targets = {}
    for _, entry in ipairs(self:GetComputerEntries()) do
        if entry.trigger then
            table.insert(targets, entry.trigger)
        end
    end
    return targets
end

function UI:GetHackableComputerEntries()
    local hackable = {}

    for _, entry in ipairs(self:GetComputerEntries()) do
        if entry.trigger and entry.trigger.Parent and self:IsHackableComputerScreen(entry.screen) then
            table.insert(hackable, entry)
        end
    end

    return hackable
end

function UI:GetCurrentFtfMapRoot(force)
    local now = tick()
    if self.currentMapRoot and self.currentMapRoot.Parent == workspace and not force then
        return self.currentMapRoot
    end

    if not force and (now - (self.lastComputerMapCheck or 0)) < 10 then
        return self.currentMapRoot
    end

    self.lastComputerMapCheck = now

    for _, obj in ipairs(workspace:GetChildren()) do
        if obj and obj:IsA("Model") and obj:FindFirstChild("ComputerTable") then
            self.currentMapRoot = obj
            return obj
        end
    end

    self.currentMapRoot = nil
    return nil
end

function UI:RefreshComputerCache(force)
    local mapRoot = self:GetCurrentFtfMapRoot(force)
    if not mapRoot then
        self.computerCache = {}
        self.computerCacheMap = nil
        return self.computerCache
    end

    local now = tick()
    if not force
        and self.computerCacheMap == mapRoot
        and self.computerCache
        and #self.computerCache > 0
        and (now - (self.lastComputerCacheRefresh or 0)) < 2
    then
        return self.computerCache
    end

    local entries = {}
    local seen = {}

    for _, descendant in ipairs(mapRoot:GetDescendants()) do
        if descendant.Name == "ComputerTrigger2" and descendant:IsA("BasePart") and descendant.Parent and not seen[descendant] then
            seen[descendant] = true
            table.insert(entries, {
                trigger = descendant,
                screen = self:GetComputerScreenFromTrigger(descendant),
            })
        end
    end

    self.computerCache = entries
    self.computerCacheMap = mapRoot
    self.lastComputerCacheRefresh = now
    return self.computerCache
end

function UI:UpdateNpcEsp()
    local state = self.espEnabledState or self:RefreshEspEnabledState()
    local playerEspEnabled = state.npcPlayer == true
    local beastEspEnabled = state.npcBeast == true

    if not playerEspEnabled and not beastEspEnabled then
        for key, _ in pairs(self.activeEspKeys.npc or {}) do
            local entry = self.espObjects[key]
            if entry then
                self:HideEspEntry(entry)
            end
        end
        self.activeEspKeys.npc = {}
        return
    end

    local seen = {}
    local uiLeft = self.window.x
    local uiTop = self.window.y
    local uiRight = self.window.x + self.window.width
    local uiBottom = self.window.y + self.window.height

    local localCharacter = LocalPlayer and LocalPlayer.Character or nil

    for _, player in ipairs(Players:GetPlayers()) do
        local model = self:GetPlayerCharacterModel(player)
        local isLocalModel = player == LocalPlayer
            or model == localCharacter
            or (LocalPlayer and model and tostring(model.Name) == tostring(LocalPlayer.Name))

        if not isLocalModel then
            local isBeast = self:IsBeastPlayer(player)
            local shouldShow = (isBeast and beastEspEnabled) or ((not isBeast) and playerEspEnabled)

            if model and shouldShow then
                local root = model:FindFirstChild("HumanoidRootPart")
                local head = model:FindFirstChild("Head") or root
                local key = "npc:" .. tostring(player.UserId or player.Name)
                local entry = self:GetEspEntry(key)
                seen[key] = true
                self.activeEspKeys.npc[key] = true

                if root and head then
                    local headPoint, headVisible = self:GetWorldToScreen(head.Position + Vector3.new(0, 0.6, 0))
                    local footPoint, footVisible = self:GetWorldToScreen(root.Position - Vector3.new(0, 3.2, 0))

                    if headVisible and footVisible and headPoint and footPoint then
                        local boxHeight = math.max(18, math.abs(footPoint.Y - headPoint.Y))
                        local boxWidth = math.max(12, math.floor(boxHeight * 0.55))
                        local boxX = math.floor(headPoint.X - (boxWidth / 2))
                        local boxY = math.floor(headPoint.Y)
                        local boxRight = boxX + boxWidth
                        local boxBottom = boxY + boxHeight
                        local espColor = isBeast and Color3.fromRGB(255, 88, 88) or Theme.accent
                        local overlapsUI = self.uiVisible
                            and boxRight >= uiLeft
                            and boxX <= uiRight
                            and boxBottom >= uiTop
                            and boxY <= uiBottom

                        if overlapsUI then
                            self:HideEspEntry(entry)
                        else
                            entry.box.Position = Vector2.new(boxX, boxY)
                            entry.box.Size = Vector2.new(boxWidth, boxHeight)
                            entry.box.Color = espColor
                            entry.box.Visible = true

                            entry.label.Text = tostring(player.Name or model.Name or "Player")
                            entry.label.Position = Vector2.new(math.floor(headPoint.X), math.floor(boxY - 16))
                            entry.label.Color = espColor
                            entry.label.Visible = true
                        end
                    else
                        self:HideEspEntry(entry)
                    end
                else
                    self:HideEspEntry(entry)
                end
            end
        end
    end

    self:CleanupTrackedEspKeys("npc", seen)
end

function UI:UpdateComputerEsp()
    local state = self.espEnabledState or self:RefreshEspEnabledState()
    local pcEspEnabled = state.pc == true

    if pcEspEnabled and not self.computerEspWasEnabled then
        self.computerCache = {}
        self.computerCacheMap = nil
        self.lastComputerCacheRefresh = 0
    end

    self.computerEspWasEnabled = pcEspEnabled

    if not pcEspEnabled then
        for key, _ in pairs(self.activeEspKeys.pc or {}) do
            local entry = self.espObjects[key]
            if entry then
                self:HideEspEntry(entry)
            end
        end
        self.activeEspKeys.pc = {}
        return
    end

    local seen = {}
    local uiLeft = self.window.x
    local uiTop = self.window.y
    local uiRight = self.window.x + self.window.width
    local uiBottom = self.window.y + self.window.height

    for index, computer in ipairs(self:GetComputerEntries()) do
        local trigger = computer.trigger
        local screen = computer.screen
        local anchor = (screen and screen.Parent and screen) or trigger

        if anchor and anchor.Parent then
            local key = "pc:" .. tostring(index)
            local entry = self:GetEspEntry(key)
            local screenPoint, visible = self:GetWorldToScreen(anchor.Position + Vector3.new(0, 1.5, 0))
            seen[key] = true
            self.activeEspKeys.pc[key] = true

            if visible and screenPoint then
                local width = 30
                local height = 30
                local boxX = math.floor(screenPoint.X - (width / 2))
                local boxY = math.floor(screenPoint.Y - (height / 2))
                local boxRight = boxX + width
                local boxBottom = boxY + height
                local overlapsUI = self.uiVisible
                    and boxRight >= uiLeft
                    and boxX <= uiRight
                    and boxBottom >= uiTop
                    and boxY <= uiBottom

                if overlapsUI then
                    self:HideEspEntry(entry)
                else
                    local sourceColor = (screen and screen.Color) or (trigger and trigger.Color) or Theme.accent
                    local r, g, b = self:GetColorRGB(sourceColor)
                    local labelText = "Hacked"
                    local espColor = Color3.fromRGB(r or 54, g or 248, b or 87)

                    if r == 13 and g == 105 and b == 172 then
                        labelText = "PC Hackable"
                    elseif r == 196 and g == 40 and b == 28 then
                        labelText = "PC Errored"
                    end

                    entry.box.Position = Vector2.new(boxX, boxY)
                    entry.box.Size = Vector2.new(width, height)
                    entry.box.Color = espColor
                    entry.box.Visible = true

                    entry.label.Text = labelText
                    entry.label.Position = Vector2.new(math.floor(screenPoint.X), math.floor(boxY - 15))
                    entry.label.Color = espColor
                    entry.label.Visible = true
                end
            else
                self:HideEspEntry(entry)
            end
        end
    end

    self:CleanupTrackedEspKeys("pc", seen)
end

