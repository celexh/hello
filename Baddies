function UI:GetPlayerHitboxParts(player)
    local character = player and player.Character
    if not character then
        return {}
    end

    local parts = {}
    local seen = {}

    for _, partName in ipairs(HitboxBodyPartNames) do
        local part = character:FindFirstChild(partName)
        if part and part:IsA("BasePart") and not seen[part] then
            seen[part] = true
            table.insert(parts, part)
        end
    end

    return parts
end

function UI:RestorePlayerHitbox(player)
    local cached = self.hitboxCache[player]
    if not cached then
        self.hitboxCache[player] = nil
        return
    end

    for _, entry in ipairs(cached) do
        if entry.part and entry.part.Parent then
            pcall(function()
                entry.part.Size = entry.size
            end)
            pcall(function()
                entry.part.CanCollide = entry.canCollide
            end)
        end
    end

    self.hitboxCache[player] = nil
end

function UI:ApplyHitboxExpander()
    local slider = self:GetHitboxSlider()
    if not slider then
        return
    end

    local multiplier = slider.value or 1
    local now = tick()
    local shouldForce = self.lastHitboxMultiplier ~= multiplier

    if multiplier <= 1 then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                self:RestorePlayerHitbox(player)
            end
        end
        self.hitboxLastApply = now
        self.lastHitboxMultiplier = multiplier
        return
    end

    if not shouldForce and (now - self.hitboxLastApply) < self.hitboxApplyInterval then
        return
    end

    self.hitboxLastApply = now
    self.lastHitboxMultiplier = multiplier

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local parts = self:GetPlayerHitboxParts(player)

            if multiplier <= 1 then
                self:RestorePlayerHitbox(player)
            elseif #parts > 0 then
                local cached = self.hitboxCache[player]
                if not cached then
                    cached = {}
                    self.hitboxCache[player] = cached
                end

                local cachedByPart = {}
                for _, entry in ipairs(cached) do
                    if entry.part then
                        cachedByPart[entry.part] = entry
                    end
                end

                for _, part in ipairs(parts) do
                    if not cachedByPart[part] then
                        local entry = {
                            part = part,
                            size = part.Size,
                            canCollide = part.CanCollide,
                        }
                        table.insert(cached, entry)
                        cachedByPart[part] = entry
                    end
                end

                for _, entry in ipairs(cached) do
                    local part = entry.part
                    if part and part.Parent then
                        local baseSize = entry.size
                        local expandedX = math.max(baseSize.X, multiplier)
                        local expandedY = math.max(baseSize.Y, multiplier)
                        local expandedZ = math.max(baseSize.Z, multiplier)

                        local currentSize = part.Size
                        local needsResize = shouldForce
                            or not currentSize
                            or currentSize.X ~= expandedX
                            or currentSize.Y ~= expandedY
                            or currentSize.Z ~= expandedZ

                        if needsResize then
                            pcall(function()
                                part.Size = Vector3.new(expandedX, expandedY, expandedZ)
                            end)
                        end

                        local currentCanCollide = part.CanCollide
                        if currentCanCollide ~= false then
                            pcall(function()
                                part.CanCollide = false
                            end)
                        end
                    end
                end
            else
                self:RestorePlayerHitbox(player)
            end
        end
    end
end

function UI:ResolveHover()
    local mousePos = self:GetMouseLocation()
    local hovered = nil
    local bestPriority = -math.huge

    for _, hitbox in ipairs(self.hitboxes) do
        if self:PointInRect(mousePos.X, mousePos.Y, hitbox.x, hitbox.y, hitbox.w, hitbox.h) then
            if hitbox.priority >= bestPriority then
                hovered = hitbox.id
                bestPriority = hitbox.priority
            end
        end
    end

    if hovered ~= self.hoveredId then
        local previous = self.hoveredId
        self.hoveredId = hovered

        if string.match(previous or "", "^tab_") or string.match(hovered or "", "^tab_") then
            self:MarkShellDirty()
            self:MarkCurrentTabDirty()
        else
            self:MarkCurrentTabDirty()
        end
    end
end

function UI:HandleInput()
    local mousePos = self:GetMouseLocation()
    local mousePressed = self:IsLeftMousePressed()

    self:ResolveHover()

    if mousePressed and not self.lastMousePressed then
        if self:IsMouseOver(self.window.x, self.window.y, self.window.width, 40) then
            self.draggingWindow = true
            self.dragOffsetX = mousePos.X - self.window.x
            self.dragOffsetY = mousePos.Y - self.window.y
        end

        for index = #self.hitboxes, 1, -1 do
            local hitbox = self.hitboxes[index]
            if self:PointInRect(mousePos.X, mousePos.Y, hitbox.x, hitbox.y, hitbox.w, hitbox.h) then
                if hitbox.onClick then
                    hitbox.onClick()
                end
                break
            end
        end
    elseif not mousePressed then
        self.draggingWindow = false
        self.draggingScroll = false
        self.draggingSlider = false
        self.activeSlider = nil
    end

    if self.draggingWindow and mousePressed then
        local newX = mousePos.X - self.dragOffsetX
        local newY = mousePos.Y - self.dragOffsetY
        if newX ~= self.window.x or newY ~= self.window.y then
            self.window.x = newX
            self.window.y = newY
            self:MarkShellDirty()
            self:MarkCurrentTabDirty()
        end
    end

    if self.draggingScroll and mousePressed and self.scroll.max > 0 then
        local _, trackY, _, trackH, thumbY, thumbH = self:GetScrollbarMetrics()
        local available = math.max(1, trackH - thumbH)
        local relative = math.clamp(mousePos.Y - trackY - self.scrollDragOffset, 0, available)
        local newOffset = (relative / available) * self.scroll.max
        if math.abs(newOffset - self.scroll.offset) > 0.5 then
            self.scroll.offset = newOffset
            self:MarkCurrentTabDirty()
        end
    end

    if self.draggingSlider and mousePressed and self.activeSlider then
        self:SetSliderFromMouse(self.activeSlider, mousePos.X)
    end

    self.lastMousePressed = mousePressed
end

function UI:HandleHotkeys()
    if self:IsKeyPressed(VK_Z) then
        local now = tick()
        if now - self.lastToggleTick > 0.2 then
            self.uiVisible = not self.uiVisible
            self.lastToggleTick = now
            self.hoveredId = nil
            self.needsRedraw = true

            if not self.uiVisible then
                self.hitboxes = {}
                self:HideBucket(self.shellBucket)
                for _, bucket in ipairs(self.tabBuckets) do
                    self:HideBucket(bucket)
                end
            else
                self:MarkShellDirty()
                self:MarkCurrentTabDirty()
            end
        end
    end
end

function UI:HandleTransientEffects()
    local now = tick()
    for tabIndex, tabControls in ipairs(self.controls) do
        for _, control in ipairs(tabControls) do
            if control.type == "button" and control.flashUntil and now >= control.flashUntil then
                control.flashUntil = nil
                self:MarkTabDirty(tabIndex)
                return
            end
        end
    end
end

