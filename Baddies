function UI:BuildATMCache()
    if self.atmCacheBuilt then
        return self.atmCache
    end

    local workspaceRef = game.Workspace or workspace
    local cache = {}
    if workspaceRef then
        for _, descendant in ipairs(workspaceRef:GetDescendants()) do
            if descendant:IsA("Model") and (
                (descendant.Name == "ATM" and self:IsTargetTypeEnabled("ATM"))
                or (descendant.Name == "CashRegister" and self:IsTargetTypeEnabled("CashRegister"))
            ) then
                local targetPart = self:GetFarmTargetPart(descendant)
                if targetPart then
                    table.insert(cache, targetPart)
                end
            end
        end
    end

    self.atmCache = cache
    self.atmCacheBuilt = true
    self:DebugLog("ATM/Register cache built: " .. tostring(#cache) .. " found")
    return cache
end

function UI:GetClosestATM(excludedATM)
    local characterRoot = self:GetCharacterRoot()
    local atmCache = self:BuildATMCache()
    if not characterRoot then
        self:DebugWarnThrottle("missing root", 2, "HumanoidRootPart was not found")
        return nil
    end

    local closestUnvisitedATM = nil
    local closestUnvisitedDistance = math.huge
    local closestAnyATM = nil
    local closestAnyDistance = math.huge
    local hasAnyUnvisitedReady = false

    for _, atm in ipairs(atmCache) do
        if self:IsATMValid(atm) and self:IsATMReady(atm) then
            local distance = (atm.Position - characterRoot.Position).Magnitude

            if atm ~= excludedATM and distance < closestAnyDistance then
                closestAnyDistance = distance
                closestAnyATM = atm
            end

            if not self:HasVisitedATM(atm) then
                hasAnyUnvisitedReady = true
                if atm ~= excludedATM and distance < closestUnvisitedDistance then
                    closestUnvisitedDistance = distance
                    closestUnvisitedATM = atm
                end
            end
        end
    end

    if closestUnvisitedATM then
        return closestUnvisitedATM
    end

    if hasAnyUnvisitedReady and excludedATM and self:IsATMValid(excludedATM) and self:IsATMReady(excludedATM) and not self:HasVisitedATM(excludedATM) then
        return excludedATM
    end

    if not closestAnyATM then
        return nil
    end

    self:DebugLog("Visited all ATM resetting cycle")
    self:ResetATMVisited()

    local resetClosestATM = nil
    local resetClosestDistance = math.huge
    for _, atm in ipairs(atmCache) do
        if self:IsATMValid(atm) and self:IsATMReady(atm) and atm ~= excludedATM then
            local distance = (atm.Position - characterRoot.Position).Magnitude
            if distance < resetClosestDistance then
                resetClosestDistance = distance
                resetClosestATM = atm
            end
        end
    end

    if resetClosestATM then
        return resetClosestATM
    end

    if excludedATM and self:IsATMValid(excludedATM) and self:IsATMReady(excludedATM) then
        return excludedATM
    end

    return nil
end

function UI:RetargetAutoFarm(excludedATM)
    self.autoFarmTarget = self:GetClosestATM(excludedATM)
    self.autoFarmLastGoal = nil
    self.autoFarmWaitUntil = 0
    self.autoFarmCashTarget = nil
    if self.autoFarmTarget then
        self:DebugLog("Targeting ATM: " .. SafeName(self.autoFarmTarget))
    else
        self:DebugWarnThrottle("no_atm_target", 1.5, "No valid ATM target found")
    end
    return self.autoFarmTarget
end

function UI:MoveTowardATM(atm, deltaTime)
    local characterRoot = self:GetCharacterRoot()
    if not characterRoot or not self:IsATMValid(atm) then
        if not characterRoot then
            self:DebugWarnThrottle("move_missing_character_root", 2, "Cannot move: HumanoidRootPart missing on local character")
        end
        return false
    end

    local targetPosition = atm.Position
    self.autoFarmLastGoal = targetPosition

    pcall(function()
        characterRoot.Velocity = Vector3.new(0, 0, 0)
    end)
    pcall(function()
        characterRoot.RotVelocity = Vector3.new(0, 0, 0)
    end)
    pcall(function()
        characterRoot.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end)
    pcall(function()
        characterRoot.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end)

    local currentPosition = characterRoot.Position
    local offset = targetPosition - currentPosition
    local distance = offset.Magnitude
    if distance <= 2 then
        return true
    end

    local moveSpeed = self:GetTweenSpeed()
    local stepDistance = math.max(0.01, (deltaTime or 0) * moveSpeed)
    local nextPosition
    if stepDistance >= distance then
        nextPosition = targetPosition
    else
        nextPosition = currentPosition + offset.Unit * stepDistance
    end

    characterRoot.CFrame = CFrame.new(nextPosition.X, nextPosition.Y, nextPosition.Z)
    return false
end

function UI:HandleAutoFarm(deltaTime)
    if not self:IsAutoFarmEnabled() then
        self:SetCharacterNoclip(false)
        self.autoFarmTarget = nil
        self.autoFarmLastGoal = nil
        self.autoFarmWaitUntil = 0
        self.autoFarmLastUpdate = 0
        self.autoFarmLastClick = 0
        self.autoFarmCashTarget = nil
        self.autoFarmLastInteract = 0
        self:ResetATMVisited()
        return
    end

    self:SetCharacterNoclip(true)

    local now = tick()
    if (now - self.autoFarmLastUpdate) < self.autoFarmUpdateInterval then
        return
    end
    self.autoFarmLastUpdate = now

    local characterRoot = self:GetCharacterRoot()
    local humanoid = self:GetCharacterHumanoid()
    if not characterRoot or not humanoid or humanoid.Health <= 0 then
        self:SetCharacterNoclip(false)
        if not characterRoot then
            self:DebugWarnThrottle("autofarm_no_character_root", 2, "Auto Farm stopped: local HumanoidRootPart missing")
        elseif not humanoid then
            self:DebugWarnThrottle("autofarm_no_humanoid", 2, "Auto Farm stopped: local Humanoid missing")
        elseif humanoid.Health <= 0 then
            self:DebugWarnThrottle("autofarm_dead", 2, "Auto Farm paused: local humanoid is dead")
        end
        return
    end

    if not self:IsATMValid(self.autoFarmTarget) then
        if self.autoFarmTarget then
            self:DebugLog("Current ATM became invalid: " .. SafeName(self.autoFarmTarget))
        end
        self:RetargetAutoFarm(nil)
    end

    if self.autoFarmTarget then
        if not self:IsATMReady(self.autoFarmTarget) then
            if not self.autoFarmCashTarget or not self:IsCashValid(self.autoFarmCashTarget) then
                self.autoFarmCashTarget = self:GetNearbyCash(nil)
                if self.autoFarmCashTarget then
                    self:DebugLog("Collecting nearby cash: " .. SafeName(self.autoFarmCashTarget))
                end
            end

            if self.autoFarmCashTarget and self:IsCashValid(self.autoFarmCashTarget) then
                local reachedCash = self:MoveTowardATM(self.autoFarmCashTarget, self.autoFarmUpdateInterval)
                if reachedCash then
                    self:PressInteractKey()
                    self.autoFarmCashTarget = self:GetNearbyCash(self.autoFarmCashTarget)
                    if self.autoFarmCashTarget then
                        self:DebugLog("Collecting next nearby cash: " .. SafeName(self.autoFarmCashTarget))
                    end
                end
                return
            end

            local previousATM = self.autoFarmTarget
            self:DebugLog("ATM robbed and no nearby cash left, moving to next")
            self:MarkATMVisited(previousATM)
            self:RetargetAutoFarm(previousATM)
            return
        end

        self.autoFarmCashTarget = nil
        local reachedATM = self:MoveTowardATM(self.autoFarmTarget, self.autoFarmUpdateInterval)
        if reachedATM then
            self:ClickATM()
        end
    end
end

function UI:HandleControlClick(control)
    if control.type == "toggle" or control.type == "checkbox" then
        control.value = not control.value
        if control.id == "auto_farm_toggle" then
            if control.value then
                self:DebugLog("Auto Farm enabled")
                self:ResetAutoFarmRoute()
                self:RetargetAutoFarm(nil)
            else
                self:DebugLog("Auto Farm disabled")
                self:SetCharacterNoclip(false)
                self:ResetAutoFarmRoute()
            end
        end
        self:SaveConfig(control.id == "auto_save_config")
    elseif control.type == "button" then
        control.flashUntil = tick() + 0.35
        if control.id == "cash_test_button" then
            self:RunCashTest()
        elseif control.id == "get_tools_button" then
            self:PrintLocalTools()
        end
    elseif control.type == "dropdown_single" or control.type == "dropdown_multi" then
        self:ToggleDropdown(control.id)
        return
    end

    self:MarkCurrentTabDirty()
end

function UI:HandleDropdownOption(control, option)
    if control.type == "dropdown_single" then
        control.value = option
        self.expandedDropdown = nil
    else
        control.selected = control.selected or {}
        control.selected[option] = not control.selected[option]
    end

    if control.id == "target_type_filter" then
        self:ResetAutoFarmRoute()
        if self:IsAutoFarmEnabled() then
            self:RetargetAutoFarm(nil)
        end
    end

    self:UpdateScrollLimit()
    self:MarkCurrentTabDirty()
    self:SaveConfig(false)
end

