function UI:UpdateHomeStats()
    local now = tick()
    if (now - (self.statsLastRefresh or 0)) < (self.statsRefreshInterval or 0.25) then
        self:SaveAllTimeMoneyMade(false)
        return
    end

    self.statsLastRefresh = now

    local currentMoney = self:GetLeaderstatValue("Dinero") or 0
    local currentKills = self:GetLeaderstatValue("Slays") or 0

    if self.lastKnownMoney == nil then
        self.lastKnownMoney = currentMoney
    elseif currentMoney > self.lastKnownMoney then
        local delta = currentMoney - self.lastKnownMoney
        self.sessionMoneyMade = (self.sessionMoneyMade or 0) + delta
        self.allTimeMoneyMade = (self.allTimeMoneyMade or 0) + delta
        self.statsSaveDirty = true
    end

    self.lastKnownMoney = currentMoney

    local uptimeSeconds = now - (self.sessionStartedAt or now)
    local hourlyMoney = 0
    if uptimeSeconds > 0 then
        hourlyMoney = (self.sessionMoneyMade or 0) * (3600 / uptimeSeconds)
    end

    local statUptime = self:GetControl(1, "stat_uptime")
    local statMoney = self:GetControl(1, "stat_money")
    local statKills = self:GetControl(1, "stat_kills")
    local statMoneyMade = self:GetControl(1, "stat_money_made")
    local statHourlyMoney = self:GetControl(1, "stat_hourly_money")
    local statAllTimeMoneyMade = self:GetControl(1, "stat_all_time_money_made")

    if statUptime then
        statUptime.value = self:FormatDuration(uptimeSeconds)
    end
    if statMoney then
        statMoney.value = self:FormatMoney(currentMoney)
    end
    if statKills then
        statKills.value = self:FormatWholeNumber(currentKills)
    end
    if statMoneyMade then
        statMoneyMade.value = self:FormatMoney(self.sessionMoneyMade or 0)
    end
    if statHourlyMoney then
        statHourlyMoney.value = self:FormatMoney(hourlyMoney) .. "/hr"
    end
    if statAllTimeMoneyMade then
        statAllTimeMoneyMade.value = self:FormatMoney(self.allTimeMoneyMade or 0)
    end

    self:SaveAllTimeMoneyMade(false)
    self:MarkTabDirty(1)
end

