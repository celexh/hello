function UI:FormatWholeNumber(value)
    local numberValue = math.floor(tonumber(value) or 0)
    local formatted = tostring(numberValue)

    while true do
        local replaced, count = string.gsub(formatted, "^(-?%d+)(%d%d%d)", "%1,%2")
        formatted = replaced
        if count == 0 then
            break
        end
    end

    return formatted
end

function UI:FormatMoney(value)
    return "$" .. self:FormatWholeNumber(value)
end

function UI:FormatDuration(secondsValue)
    local totalSeconds = math.max(0, math.floor(tonumber(secondsValue) or 0))
    local hours = math.floor(totalSeconds / 3600)
    local minutes = math.floor((totalSeconds % 3600) / 60)
    local seconds = totalSeconds % 60

    if hours > 0 then
        return string.format("%dh %dm %ds", hours, minutes, seconds)
    end

    if minutes > 0 then
        return string.format("%dm %ds", minutes, seconds)
    end

    return string.format("%ds", seconds)
end

