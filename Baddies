function UI:FlattenOffsetsTable(prefix, source, output)
    if type(source) ~= "table" then
        return
    end

    for key, value in pairs(source) do
        local keyName = tostring(key)
        local path = prefix ~= "" and (prefix .. "." .. keyName) or keyName
        if type(value) == "number" then
            output[path] = value
        elseif type(value) == "table" then
            self:FlattenOffsetsTable(path, value, output)
        end
    end
end

function UI:LoadOffsets()
    if self.offsetsLoaded or self.offsetsLoadAttempted then
        return self.offsetsLoaded
    end

    self.offsetsLoadAttempted = true

    local httpMethod = game and (game.HttpGet or game.httpget)
    if type(httpMethod) ~= "function" or not HttpService then
        self:DebugWarn("Offsets loader unavailable: HttpGet/HttpService missing")
        return false
    end

    local ok, response = pcall(function()
        return httpMethod(game, self.offsetsUrl)
    end)

    if not ok or not response or response == "" then
        self:DebugWarn("Failed to download offsets JSON")
        return false
    end

    local decodeOk, decoded = pcall(function()
        return HttpService:JSONDecode(response)
    end)

    if not decodeOk or type(decoded) ~= "table" then
        self:DebugWarn("Failed to parse offsets JSON")
        return false
    end

    local flat = {}
    self:FlattenOffsetsTable("", decoded.Offsets or {}, flat)

    self.offsetsData = decoded
    self.flatOffsets = flat
    self.offsetsLoaded = true

    local totalOffsets = tonumber(decoded["Total Offsets"]) or 0
    local flatCount = 0
    for _ in pairs(flat) do
        flatCount = flatCount + 1
    end

    return true
end

function UI:GetOffset(path)
    if not self.offsetsLoaded then
        self:LoadOffsets()
    end

    return self.flatOffsets[path]
end

function UI:GetInstanceAddress(instance)
    if not instance then
        return nil
    end

    local ok, directAddress = pcall(function()
        return instance.Address
    end)
    if ok and type(directAddress) == "number" and directAddress > 0 then
        return directAddress
    end

    local resolvers = {
        getinstanceaddress,
        get_instance_address,
        getaddressfrominstance,
        get_address_from_instance,
    }

    for _, resolver in ipairs(resolvers) do
        if type(resolver) == "function" then
            local ok, address = pcall(resolver, instance)
            if ok and type(address) == "number" and address > 0 then
                return address
            end
        end
    end

    local ok, address = pcall(function()
        return tonumber(instance)
    end)
    if ok and type(address) == "number" and address > 0 then
        return address
    end

    return nil
end

