function UI:GetNearbyCash(excludedCash)
    local characterRoot = self:GetCharacterRoot()
    if not characterRoot or not characterRoot.Position then
        return nil
    end

    local workspaceRef = game.Workspace or workspace
    if not workspaceRef then
        return nil
    end

    local cashFolder = workspaceRef:FindFirstChild("Cash")
    local candidates = cashFolder and cashFolder:GetDescendants() or workspaceRef:GetDescendants()
    local closestCash = nil
    local closestDistance = math.huge

    for _, descendant in ipairs(candidates) do
        if descendant ~= excludedCash and descendant.Name == "Cash" and self:IsCashValid(descendant) then
            local position = descendant.Position
            if position then
                local distance = (position - characterRoot.Position).Magnitude
                if distance <= 15 and distance < closestDistance then
                    closestDistance = distance
                    closestCash = descendant
                end
            end
        end
    end

    return closestCash
end

