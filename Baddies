function UI:WriteHumanoidAutoRotate(enabled)
    local humanoid = self:GetCharacterHumanoid()
    if not humanoid then
        return false
    end

    local offset = self:GetOffset("Humanoid.AutoRotate")
    local address = self:GetInstanceAddress(humanoid)

    if offset and address and type(memory_write) == "function" then
        local ok = pcall(function()
            memory_write("byte", address + offset, enabled and 1 or 0)
        end)
        if ok then
            self.combatAutoRotateState = enabled
            return true
        end
    end

    local propertyOk = pcall(function()
        humanoid.AutoRotate = enabled
    end)
    if propertyOk then
        self.combatAutoRotateState = enabled
        return true
    end

    return false
end

function UI:SetCharacterNoclip(enabled)
    if self.noclipEnabled == enabled then
