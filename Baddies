function UI:HandleCombat(deltaTime)
    self:RefreshCombatPlayerOptions(false)

    local toggle = self:GetKillPlayerToggle()
    if not toggle or toggle.value ~= true then
        self:SetCombatLeftMouseHeld(false)
        self:SetCombatInteractHeld(false)
        if not self:IsAutoFarmEnabled() then
            self:SetCharacterNoclip(false)
        end
        self.combatTarget = nil
        self.combatLastUpdate = 0
        self.combatLastClick = 0
        self.combatRetreating = false
        self.combatRetreatAnchor = nil
        self.combatStomping = false
        self.combatStompStartedAt = 0
        self.combatStompTarget = nil
        return
    end

    local now = tick()
    if (now - self.combatLastUpdate) < self.combatUpdateInterval then
        return
    end
    self.combatLastUpdate = now

    local targetPlayer = self:GetSelectedCombatPlayer()
    if not targetPlayer or targetPlayer == LocalPlayer then
        self:SetCombatLeftMouseHeld(false)
        self:SetCombatInteractHeld(false)
        if not self:IsAutoFarmEnabled() then
            self:SetCharacterNoclip(false)
        end
        self.combatTarget = nil
        return
    end

    local targetCharacter = targetPlayer.Character
    local targetRoot = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart") or nil
    local targetHumanoid = targetCharacter and targetCharacter:FindFirstChildOfClass("Humanoid") or nil
    local localRoot = self:GetCharacterRoot()
    local localHumanoid = self:GetCharacterHumanoid()

    if not localRoot or not localHumanoid or localHumanoid.Health <= 0 then
        self:SetCombatLeftMouseHeld(false)
        self:SetCombatInteractHeld(false)
        if not self:IsAutoFarmEnabled() then
            self:SetCharacterNoclip(false)
        end
        self.combatRetreating = false
        self.combatRetreatAnchor = nil
        self.combatStomping = false
        self.combatStompStartedAt = 0
        self.combatStompTarget = nil
        return
    end

    local ownHealth = localHumanoid.Health or 0
    local retreatThreshold = 15

    if ownHealth <= retreatThreshold and not self.combatRetreating then
        self.combatRetreating = true
        self.combatRetreatAnchor = localRoot.Position + Vector3.new(0, 100, 0)
        self:NotifyPlayer("Low HP, retreating", "Windy Combat", 2)
    end

    if self.combatRetreating then
        self:SetCharacterNoclip(true)
        self:SetCombatLeftMouseHeld(false)
        self:SetCombatInteractHeld(false)

        pcall(function()
            localRoot.Velocity = Vector3.new(0, 0, 0)
        end)
        pcall(function()
            localRoot.RotVelocity = Vector3.new(0, 0, 0)
        end)
        pcall(function()
            localRoot.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        end)
        pcall(function()
            localRoot.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        end)

        if ownHealth >= 50 then
            self.combatRetreating = false
            self.combatRetreatAnchor = nil
            self:SetCombatInteractHeld(false)
            self:NotifyPlayer("Recovered, resuming combat", "Windy Combat", 2)
            return
        end

        local retreatPosition = self.combatRetreatAnchor or (localRoot.Position + Vector3.new(0, 100, 0))
        pcall(function()
            localRoot.CFrame = CFrame.new(retreatPosition.X, retreatPosition.Y, retreatPosition.Z)
        end)
        return
    end

    local equippedTool = self:GetEquippedCombatTool()
    if not equippedTool then
        self:SetCombatLeftMouseHeld(false)
        self:SetCombatInteractHeld(false)
        if not self:IsAutoFarmEnabled() then
            self:SetCharacterNoclip(false)
        end
        self.combatTarget = nil
        self:DebugWarnThrottle("combat_missing_tool", 2, "Combat requires PinkStopSignal or 1 punches equipped")
        self:NotifyPlayer("Equip PinkStopSignal or 1 punches first", "Windy Combat", 3)
        return
    end

    if not targetRoot or not targetHumanoid or targetHumanoid.Health <= 0 then
        self:SetCombatLeftMouseHeld(false)
        self:SetCombatInteractHeld(false)
        if not self:IsAutoFarmEnabled() then
            self:SetCharacterNoclip(false)
        end
        self.combatTarget = nil
        return
    end

    local targetHealth = targetHumanoid.Health or 0
    local targetMaxHealth = targetHumanoid.MaxHealth or 100
    local lowHealthThreshold = math.max(1, targetMaxHealth * 0.05)
    if self.combatStomping then
        self:SetCharacterNoclip(true)
        local stompRoot = self.combatStompTarget and self.combatStompTarget.Parent and self.combatStompTarget or targetRoot
        local stompPosition = stompRoot and stompRoot.Position or localRoot.Position
        local stompTopPosition = stompPosition + Vector3.new(0, 3, 0)

        self:SetCombatLeftMouseHeld(false)
        self:SetCombatInteractHeld(false)

        pcall(function()
            localRoot.Velocity = Vector3.new(0, 0, 0)
        end)
        pcall(function()
            localRoot.RotVelocity = Vector3.new(0, 0, 0)
        end)
        pcall(function()
            localRoot.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        end)
        pcall(function()
            localRoot.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        end)
        pcall(function()
            localRoot.CFrame = CFrame.new(stompTopPosition.X, stompTopPosition.Y, stompTopPosition.Z)
        end)

        self:TapCombatInteract()

        if (tick() - self.combatStompStartedAt) >= 2 then
            self:SetCombatInteractHeld(false)
            self.combatTarget = nil
            toggle.value = false
            self.combatLastUpdate = 0
            self.combatLastClick = 0
            self.combatRetreating = false
            self.combatRetreatAnchor = nil
            self.combatStomping = false
            self.combatStompStartedAt = 0
            self.combatStompTarget = nil
            self:MarkTabDirty(3)
            self:NotifyPlayer("Stomp finished, stopping combat", "Windy Combat", 2)
        end
        return
    end

    if targetHealth <= lowHealthThreshold then
        self:SetCombatLeftMouseHeld(false)
        self:SetCombatInteractHeld(false)
        self.combatStomping = true
        self.combatStompStartedAt = tick()
        self.combatStompTarget = targetRoot
        self:NotifyPlayer("Target low health, stomping", "Windy Combat", 2)
        return
    end

    self.combatTarget = targetPlayer
    self:SetCombatLeftMouseHeld(false)
    self:SetCombatInteractHeld(false)

    pcall(function()
        localRoot.Velocity = Vector3.new(0, 0, 0)
    end)
    pcall(function()
        localRoot.RotVelocity = Vector3.new(0, 0, 0)
    end)
    pcall(function()
        localRoot.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end)
    pcall(function()
        localRoot.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end)

    local behindDistance = 1.75
    local targetPosition = targetRoot.Position - (targetRoot.CFrame.LookVector * behindDistance)
    local offset = targetPosition - localRoot.Position
    local distance = offset.Magnitude
    if distance <= 2.25 then
        if not self:IsAutoFarmEnabled() then
            self:SetCharacterNoclip(false)
        end
        self:ClickCombatAttack()
        return
    end

    self:SetCharacterNoclip(true)

    local moveSpeed = self:GetTweenSpeed()
    local stepDelta = self.combatUpdateInterval
    local stepDistance = math.max(0.01, stepDelta * moveSpeed)
    local nextPosition
    if stepDistance >= distance then
        nextPosition = targetPosition
    else
        nextPosition = localRoot.Position + (offset.Unit * stepDistance)
    end

    pcall(function()
        localRoot.CFrame = CFrame.new(nextPosition.X, nextPosition.Y, nextPosition.Z)
    end)
end

