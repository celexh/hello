function UI:RefreshCombatPlayerOptions(force)
    local now = tick()
    if not force and (now - self.combatPlayerRefreshAt) < self.combatPlayerRefreshInterval then
        return
    end

    self.combatPlayerRefreshAt = now

    local control = self:GetKillPlayerTargetControl()
    if not control then
        return
    end

    local options = {}
    local previousValue = control.value
    local previousCount = #(control.options or {})
    local previousSignature = table.concat(control.options or {}, "\0")
    local selectedStillExists = false

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(options, player.Name)
            if control.value == player.Name then
                selectedStillExists = true
            end
        end
    end

    table.sort(options)
    control.options = options

    if #options == 0 then
        control.value = ""
    elseif not selectedStillExists then
        control.value = options[1]
    end

    local newSignature = table.concat(options, "\0")
    if previousCount ~= #options or previousSignature ~= newSignature or previousValue ~= control.value then
        self:MarkTabDirty(3)
    end
end

