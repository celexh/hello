function UI:PrintLocalTools()
    if not LocalPlayer then
        print("LocalPlayer missing")
        return
    end

    local toolNames = {}
    local seen = {}

    local function isRealTool(instance)
        if not instance then
            return false
        end

        local className = tostring(instance.ClassName or "")
        return className == "Tool" or className == "HopperBin"
    end

    local function collectTools(container, sourceName)
        if not container then
            return
        end

        for _, child in ipairs(container:GetChildren()) do
            if isRealTool(child) then
                local key = sourceName .. ":" .. tostring(child.Name)
                if not seen[key] then
                    seen[key] = true
                    table.insert(toolNames, "[" .. sourceName .. "] " .. tostring(child.Name))
                end
            end
        end
    end

    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack") or LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character

    collectTools(backpack, "Backpack")
    collectTools(character, "Equipped")

    if #toolNames == 0 then
        print("[Windy Tools] No tools found")
        return
    end

    table.sort(toolNames)
    for _, entry in ipairs(toolNames) do
        print("[Windy Tools] " .. entry)
    end
end

