function UI:SetStatValue(controlId, value)
    local control = self:GetControl(1, controlId)
    local nextValue = tostring(value or "")
    if control and control.value ~= nextValue then
        control.value = nextValue
        self.tabDirty[1] = true
        self.needsRedraw = true
    end
end

function UI:FormatDuration(seconds)
    local total = math.max(0, math.floor(tonumber(seconds) or 0))
    local hours = math.floor(total / 3600)
    local minutes = math.floor((total % 3600) / 60)
    local secs = total % 60

    if hours > 0 then
        return string.format("%dh %dm %ds", hours, minutes, secs)
    end

    if minutes > 0 then
        return string.format("%dm %ds", minutes, secs)
    end

    return string.format("%ds", secs)
end

function UI:RefreshHomeStats(force)
    local now = tick()
    if not force and (now - (self.lastHomeStatRefresh or 0)) < 1 then
        return
    end

    self.lastHomeStatRefresh = now

    local player = nil
    local coinsValue = "0"
    local teamValue = "None"

    if LocalPlayer and LocalPlayer.Name then
        player = Players:FindFirstChild(LocalPlayer.Name) or LocalPlayer
    else
        player = LocalPlayer
    end

    if player then
        local playerData = player:FindFirstChild("PlayerData")
        local credits = playerData and playerData:FindFirstChild("Credits")
        if credits then
            local ok, value = pcall(function()
                return credits.Value
            end)

            if ok and value ~= nil then
                coinsValue = tostring(value)
            end
        end

        local taggedPlayers = {}
        for _, candidate in ipairs(Players:GetPlayers()) do
            local candidateData = candidate and candidate:FindFirstChild("PlayerData")
            local itValue = candidateData and candidateData:FindFirstChild("It")
            if itValue then
                local ok, value = pcall(function()
                    return itValue.Value
                end)

                if ok and (value == true or value == 1 or value == "1") then
                    table.insert(taggedPlayers, tostring(candidate.Name or "Unknown"))
                end
            end
        end

        if #taggedPlayers > 0 then
            teamValue = table.concat(taggedPlayers, ", ")
        end
    end

    self:SetStatValue("uptime_stat", self:FormatDuration(now - (self.launchTick or now)))
    self:SetStatValue("coins_stat", coinsValue)
    self:SetStatValue("profile_team_stat", teamValue)
    if self.lastConfigSaveTick then
        self:SetStatValue("last_save_stat", self:FormatDuration(now - self.lastConfigSaveTick) .. " ago")
    else
        self:SetStatValue("last_save_stat", "Never")
    end
end

