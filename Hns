UI:Render()

RunService.RenderStepped:Connect(function(deltaTime)
    if not UI.isRunning then
        return
    end

    pcall(function()
        UI:HandleHotkeys()
    end)

    pcall(function()
        UI:RefreshHomeStats(false)
    end)

    pcall(function()
        UI:RefreshESP()
    end)

    pcall(function()
        UI:RefreshCoinESP()
    end)

    pcall(function()
        UI:HandleCoinFarm(deltaTime)
    end)

    if UI.uiVisible then
        pcall(function()
            UI:HandleInput()
        end)

        pcall(function()
            UI:HandleTransientEffects()
        end)
    end

    if UI.needsRedraw then
        pcall(function()
            UI:Render()
        end)
    end
end)
