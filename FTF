function UI:StartAutoDo()
    self:StopAutoDo()
    local eKey = 0x45
    local tolerance = 10.5

    self.autoDoThread = task.spawn(function()
        local hasPressed = false
        while true do
            local control = self:GetControl(3, "auto_do_toggle")
            if control and control.value then
                local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
                local screenGui = playerGui and playerGui:FindFirstChild("ScreenGui")
                local timingCircle = screenGui and screenGui:FindFirstChild("TimingCircle")
                local timingPin = timingCircle and timingCircle:FindFirstChild("TimingPin")
                local timingBase = timingCircle and timingCircle:FindFirstChild("TimingBase")

                if timingCircle and timingPin and timingBase then
                    local ok, circleVisible = pcall(memory_read, "byte", timingCircle.Address + 0x5b5)
                    if ok and circleVisible == 1 then
                        local pinOk, pinRotation = pcall(memory_read, "float", timingPin.Address + 0x188)
                        local baseOk, baseRotation = pcall(memory_read, "float", timingBase.Address + 0x188)
                        if pinOk and baseOk then
                            local diff = math.abs(pinRotation - baseRotation)
                            if diff > 180 then diff = 360 - diff end
                            if diff <= tolerance and not hasPressed then
                                task.wait(0.08)
                                keypress(eKey)
                                task.wait(0.05)
                                keyrelease(eKey)
                                hasPressed = true
                            end
                        end
                    else
                        hasPressed = false
                    end
                end
                task.wait(0.1)
            else
                hasPressed = false
                task.wait(0.1)
            end
        end
    end)
end

function UI:StopAutoDo()
    if self.autoDoThread then
        task.cancel(self.autoDoThread)
        self.autoDoThread = nil
    end
end

function UI:UpdateNpcEsp()
    local state = self.espEnabledState or self:RefreshEspEnabledState()
    local playerEspEnabled = state.npcPlayer == true
    local beastEspEnabled = state.npcBeast == true

    if not playerEspEnabled and not beastEspEnabled then
        for key, _ in pairs(self.activeEspKeys.npc or {}) do
            local entry = self.espObjects[key]
            if entry then
                self:HideEspEntry(entry)
            end
        end
        self.activeEspKeys.npc = {}
        return
    end

    local localCharacter = LocalPlayer and LocalPlayer.Character or nil
    local seen = {}
    local uiLeft = self.window.x
    local uiTop = self.window.y
    local uiRight = self.window.x + self.window.width
    local uiBottom = self.window.y + self.window.height

    for _, obj in ipairs(self:GetFtfCharacterTargets()) do
        local isLocalModel = obj == localCharacter
            or (LocalPlayer and tostring(obj.Name) == tostring(LocalPlayer.Name))

        if self:IsFtfCharacterModel(obj) and not isLocalModel then
            local isBeast = self:IsBeastModel(obj)
            local shouldShow = (isBeast and beastEspEnabled) or ((not isBeast) and playerEspEnabled)

            if shouldShow then
                local root = obj:FindFirstChild("HumanoidRootPart")
                local head = obj:FindFirstChild("Head") or root
                local key = tostring(obj)
                local entry = self:GetEspEntry(key)
                seen[key] = true
                self.activeEspKeys.npc[key] = true

                if root and head then
                    local headPoint, headVisible = self:GetWorldToScreen(head.Position + Vector3.new(0, 0.6, 0))
                    local footPoint, footVisible = self:GetWorldToScreen(root.Position - Vector3.new(0, 3.2, 0))

                    if headVisible and footVisible and headPoint and footPoint then
                        local boxHeight = math.max(18, math.abs(footPoint.Y - headPoint.Y))
                        local boxWidth = math.max(12, math.floor(boxHeight * 0.55))
                        local boxX = math.floor(headPoint.X - (boxWidth / 2))
                        local boxY = math.floor(headPoint.Y)
                        local boxRight = boxX + boxWidth
                        local boxBottom = boxY + boxHeight
                        local espColor = isBeast and Color3.fromRGB(255, 88, 88) or Theme.accent
                        local overlapsUI = self.uiVisible
                            and boxRight >= uiLeft
                            and boxX <= uiRight
                            and boxBottom >= uiTop
                            and boxY <= uiBottom

                        if overlapsUI then
                            self:HideEspEntry(entry)
                        else
                            entry.box.Position = Vector2.new(boxX, boxY)
                            entry.box.Size = Vector2.new(boxWidth, boxHeight)
                            entry.box.Color = espColor
                            entry.box.Visible = true

                            entry.label.Text = tostring(obj.Name or "NPC")
                            entry.label.Position = Vector2.new(math.floor(headPoint.X), math.floor(boxY - 16))
                            entry.label.Color = espColor
                            entry.label.Visible = true
                        end
                    else
                        self:HideEspEntry(entry)
                    end
                else
                    self:HideEspEntry(entry)
                end
            else
                local existing = self.espObjects[tostring(obj)]
                if existing then
                    self:HideEspEntry(existing)
                end
            end
        end
    end

    for key, entry in pairs(self.espObjects) do
        if self.activeEspKeys.npc[key] and not seen[key] then
            self:HideEspEntry(entry)
            self.activeEspKeys.npc[key] = nil
        end
    end
end

