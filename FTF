function UI:IsFtfCharacterModel(model)
    if not model or not model:IsA("Model") then
        return false
    end

    return model:FindFirstChild("HumanoidRootPart") ~= nil
end

function UI:IsBeastModel(model)
    local hammer = model and model:FindFirstChild("Hammer")
    return hammer and hammer:FindFirstChild("Handle") ~= nil or false
end

function UI:IsValidFtfCharacterTarget(model)
    return self:IsFtfCharacterModel(model)
        and model:IsDescendantOf(workspace)
end

function UI:RefreshFtfCharacterCache(force)
    local now = tick()
    if not force and (now - (self.lastFtfCharacterCacheRefresh or 0)) < 2 then
        return self.ftfCharacterCache or {}
    end

    local results = {}
    local seen = {}

    for _, player in ipairs(Players:GetPlayers()) do
        local model = player.Character
        if not model or not model:IsDescendantOf(workspace) then
            model = workspace:FindFirstChild(player.Name)
        end

        if model and self:IsValidFtfCharacterTarget(model) and not seen[model] then
            seen[model] = true
            table.insert(results, model)
        end
    end

    self.ftfCharacterCache = results
    self.lastFtfCharacterCacheRefresh = now
    return results
end

function UI:GetFtfCharacterTargets()
    local cached = self:RefreshFtfCharacterCache(false)
    local valid = {}

    for _, target in ipairs(cached or {}) do
        if self:IsValidFtfCharacterTarget(target) then
            table.insert(valid, target)
        end
    end

    if #valid ~= #(cached or {}) then
        self.ftfCharacterCache = valid
    end

    if #valid > 0 then
        return valid
    end

    return self:RefreshFtfCharacterCache(true)
end

function UI:GetCurrentFtfMapRoot(force)
    local now = tick()
    if self.currentMapRoot and self.currentMapRoot.Parent == workspace and not force then
        return self.currentMapRoot
    end

    if not force and (now - (self.lastComputerMapCheck or 0)) < 10 then
        return self.currentMapRoot
    end

    self.lastComputerMapCheck = now

    for _, obj in ipairs(workspace:GetChildren()) do
        if obj and obj:IsA("Model") and obj:FindFirstChild("ComputerTable") then
            self.currentMapRoot = obj
            return obj
        end
    end

    self.currentMapRoot = nil
    return nil
end

function UI:RefreshComputerCache(force)
    local mapRoot = self:GetCurrentFtfMapRoot(force)

    if not mapRoot then
        self.computerCache = {}
        self.computerCacheMap = nil
        return self.computerCache
    end

    if not force and self.computerCacheMap == mapRoot and self.computerCache then
        return self.computerCache
    end

    local results = {}
    local seen = {}

    for _, obj in ipairs(mapRoot:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name == "ComputerTrigger2" then
            local parentModel = self:GetComputerTableAncestor(obj)
            if parentModel and not seen[obj] then
                seen[obj] = true
                table.insert(results, obj)
            end
        end
    end

    self.computerCache = results
    self.computerCacheMap = mapRoot
    self.lastComputerCacheRefresh = tick()
    return results
end

function UI:GetComputerTargets()
    local mapRoot = self:GetCurrentFtfMapRoot(false)
    if mapRoot ~= self.computerCacheMap then
        return self:RefreshComputerCache(true)
    end

    return self:RefreshComputerCache(false)
end

function UI:RefreshFreezePodCache(force)
    local mapRoot = self:GetCurrentFtfMapRoot(false)

    if not mapRoot then
        self.freezePodCache = {}
        self.freezePodCacheMap = nil
        return self.freezePodCache
    end

    if not force and self.freezePodCacheMap == mapRoot and #self.freezePodCache > 0 then
        return self.freezePodCache
    end

    local results = {}

    for _, obj in ipairs(mapRoot:GetChildren()) do
        if obj and obj:IsA("Model") and obj.Name == "FreezePod" then
            local anchor = obj:FindFirstChild("BasePart")
            if anchor and anchor:IsA("BasePart") then
                table.insert(results, anchor)
            end
        end
    end

    self.freezePodCache = results
    self.freezePodCacheMap = mapRoot
    return results
end

function UI:GetFreezePodTargets()
    return self:RefreshFreezePodCache(false)
end

function UI:RefreshExitDoorCache(force)
    local mapRoot = self:GetCurrentFtfMapRoot(false)

    if not mapRoot then
        self.exitDoorCache = {}
        self.exitDoorColorCache = {}
        self.exitDoorCacheMap = nil
        return self.exitDoorCache
    end

    if not force and self.exitDoorCacheMap == mapRoot and #self.exitDoorCache > 0 then
        return self.exitDoorCache
    end

    local results = {}
    local colors = {}

    for _, obj in ipairs(mapRoot:GetChildren()) do
        if obj and obj:IsA("Model") and obj.Name == "ExitDoor" then
            local anchor = obj:FindFirstChild("ExitArea")
            if anchor and anchor:IsA("BasePart") then
                local light = obj:FindFirstChild("Light")
                local lightColor = (light and light:IsA("BasePart") and light.Color) or Color3.fromRGB(255, 255, 0)
                table.insert(results, anchor)
                colors[anchor] = lightColor
            end
        end
    end

    self.exitDoorCache = results
    self.exitDoorColorCache = colors
    self.exitDoorCacheMap = mapRoot
    return results
end

function UI:GetExitDoorTargets()
    return self:RefreshExitDoorCache(false)
end

function UI:GetComputerTableAncestor(instance)
    local current = instance
    while current and current ~= workspace do
        if current.Name == "ComputerTable" and current:IsA("Model") then
            return current
        end
        current = current.Parent
    end

    return nil
end

