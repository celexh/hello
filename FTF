function UI:CanLocalPlayerAct()
    local character = LocalPlayer and LocalPlayer.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    local root = character and character:FindFirstChild("HumanoidRootPart")

    if not character or not humanoid or not root then
        return false
    end

    if humanoid.Health <= 0 then
        return false
    end

    return true
end

function UI:GetCapturedPlayerTarget()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local statsModule = player:FindFirstChild("TempPlayerStatsModule")
            local captured = statsModule and statsModule:FindFirstChild("Captured")
            local capturedValue = captured and captured.Value

            if capturedValue == true or capturedValue == 1 then
                local character = player.Character
                local root = character and character:FindFirstChild("HumanoidRootPart")
                if root then
                    return player, root
                end
            end
        end
    end

    return nil, nil
end

function UI:BuildSaveCapturedCFrame(root)
    return root.CFrame * CFrame.new(0, -4.5, 0) * CFrame.Angles(math.rad(90), 0, 0)
end

function UI:StartSaveCaptured()
    self:StopSaveCaptured()

    local interactKey = 0x45

    self.saveCapturedThread = task.spawn(function()
        local savedReturnCFrame = nil
        local activeTargetUserId = nil

        while true do
            local control = self:GetControl(3, "save_captured_toggle")
            if not (control and control.value) then
                if savedReturnCFrame and self:CanLocalPlayerAct() then
                    local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if localRoot then
                        localRoot.CFrame = savedReturnCFrame
                    end
                end
                savedReturnCFrame = nil
                activeTargetUserId = nil
                task.wait(0.15)
            else
                if type(isrbxactive) == "function" then
                    local ok, active = pcall(isrbxactive)
                    if not ok or not active then
                        local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if savedReturnCFrame and localRoot then
                            localRoot.CFrame = savedReturnCFrame
                        end
                        savedReturnCFrame = nil
                        activeTargetUserId = nil
                        task.wait(0.15)
                        continue
                    end
                end

                local localCharacter = LocalPlayer and LocalPlayer.Character
                local localRoot = localCharacter and localCharacter:FindFirstChild("HumanoidRootPart")

                if self:CanLocalPlayerAct() and localRoot then
                    local targetPlayer, targetRoot = self:GetCapturedPlayerTarget()

                    if targetPlayer and targetRoot then
                        if activeTargetUserId ~= targetPlayer.UserId or not savedReturnCFrame then
                            savedReturnCFrame = localRoot.CFrame
                            activeTargetUserId = targetPlayer.UserId
                        end

                        local targetCFrame = self:BuildSaveCapturedCFrame(targetRoot)
                        localRoot.CFrame = targetCFrame
                        keypress(interactKey)
                        task.wait(0.03)
                        keyrelease(interactKey)

                        local statsModule = targetPlayer:FindFirstChild("TempPlayerStatsModule")
                        local captured = statsModule and statsModule:FindFirstChild("Captured")
                        local capturedValue = captured and captured.Value

                        if capturedValue ~= true and capturedValue ~= 1 then
                            if savedReturnCFrame and localRoot then
                                localRoot.CFrame = savedReturnCFrame
                            end
                            savedReturnCFrame = nil
                            activeTargetUserId = nil
                            task.wait(0.1)
                        else
                            task.wait(0.06)
                        end
                    else
                        if savedReturnCFrame and localRoot then
                            localRoot.CFrame = savedReturnCFrame
                        end
                        savedReturnCFrame = nil
                        activeTargetUserId = nil
                        task.wait(0.15)
                    end
                else
                    if savedReturnCFrame and localRoot then
                        localRoot.CFrame = savedReturnCFrame
                    end
                    savedReturnCFrame = nil
                    activeTargetUserId = nil
                    task.wait(0.15)
                end
            end
        end
    end)
end

