    txt.Text = text
    txt.Color = Color3.fromRGB(255, 255, 255)
    txt.Visible = true
    txt.Transparency = 1
    txt.Outline = true
    txt.ZIndex = 6
    
    local btn = {bg = bg, txt = txt, x = x, y = y, w = w, h = h, onClick = onClick}
    table.insert(buttons, btn)
    return btn
end

