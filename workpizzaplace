function UI:StartTweenToCFrame(targetCFrame)
    if not targetCFrame then
        return false
    end

    local root = self:GetLocalRootPart()
    if not root then
        return false
    end

    local currentPosition = root.Position
    local finalPosition = targetCFrame.Position
    local stages = {
        CFrame.new(currentPosition.X, 70, currentPosition.Z),
        CFrame.new(finalPosition.X, 80, finalPosition.Z),
        CFrame.new(finalPosition.X, finalPosition.Y, finalPosition.Z),
    }

    self.teleportTweenStages = stages
    self.teleportTweenStageIndex = 1
    self.teleportTweenTarget = stages[1]
    self.teleportTweenUseStages = true
    return true
end

function UI:StartDirectTweenToCFrame(targetCFrame)
