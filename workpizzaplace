function UI:AutoDeliverPizzaStep()
    if not self:IsToggleEnabled("auto_deliver_pizza") then
        self.farmStatusText = "Off"
        return
    end

    local root = self:GetLocalRootPart()
    if not root then
        self.farmStatusText = "Waiting Character"
        return
    end

    local equippedTool, deliveryHouse = self:GetEquippedPizzaDelivery()
    if not equippedTool then
        if self:CountBackpackPizzaDeliveries() > 0 then
            self.pizzaIdleLapComplete = false
            self.farmStatusText = "Equipping"
            self:TryEquipPizzaDeliveryFromHotbar()
            task.wait(1)
        else
            local worldPizzaCount = self:CountWorldPizzaDeliveries()
            if worldPizzaCount <= 0 then
                if not self.pizzaIdleLapComplete then
                    self.farmStatusText = "Idle Lap"
                    local route = self.pizzaPickupRoute or {}
                    for _ = 1, #route do
                        if not self.isRunning or not self:IsToggleEnabled("auto_deliver_pizza") then
                            break
                        end
                        self:AdvancePizzaPickupRoute()
                        task.wait(0.15)
                    end
                    self.pizzaIdleLapComplete = true
                else
                    self.farmStatusText = "Waiting Pizzas"
                    task.wait(0.5)
                end
            else
                self.pizzaIdleLapComplete = false
                self.farmStatusText = "Scanning Route"
                local routeStart = tick()
                while self.isRunning and self:IsToggleEnabled("auto_deliver_pizza") do
                    local liveTool = self:GetEquippedPizzaDelivery()
                    if liveTool then
                        break
                    end

                    if self:CountBackpackPizzaDeliveries() > 0 then
                        self.farmStatusText = "Equipping"
                        self:TryEquipPizzaDeliveryFromHotbar()
                        task.wait(1)
                        break
                    end

                    if self:CountWorldPizzaDeliveries() <= 0 then
                        self.farmStatusText = "Waiting Pizzas"
                        break
                    end

                    self.farmStatusText = "Scanning Route"
                    self:AdvancePizzaPickupRoute()
                    task.wait(0.15)

                    if (tick() - routeStart) >= 5 then
                        routeStart = tick()
                    end
                end
            end
        end
        return
    end

    self.pizzaIdleLapComplete = false

    while self.isRunning and self:IsToggleEnabled("auto_deliver_pizza") do
        local liveTool, liveHouse = self:GetEquippedPizzaDelivery()
        if not liveTool or not liveHouse then
            break
        end

        if liveTool ~= equippedTool or liveHouse ~= deliveryHouse then
            equippedTool = liveTool
            deliveryHouse = liveHouse
        end

        local doorTouch = self:GetHouseDoorTouch(deliveryHouse)
        if not doorTouch then
            self.farmStatusText = "Waiting Door"
            task.wait(0.15)
            continue
        end

        self.farmStatusText = "Delivering"
        self:MoveToCFrame(CFrame.new(doorTouch.Position.X, doorTouch.Position.Y, doorTouch.Position.Z), false)
        if self:GetMovementMode() == "Tween" then
            while self.isRunning and self:IsToggleEnabled("auto_deliver_pizza") and self:IsTweenActive() do
                task.wait(0.1)
            end
        end
        task.wait(0.25)
        break
    end

    if not self:IsToggleEnabled("auto_deliver_pizza") then
        return
    end

    local liveTool = self:GetEquippedPizzaDelivery()
    if liveTool then
        self.farmStatusText = "Retrying Delivery"
        task.wait(0.4)
    else
        self.farmStatusText = "Delivered"
        task.wait(0.8)
    end
end

function UI:EnsureAutoDeliverLoop()
    if self.autoDeliverLoopRunning then
