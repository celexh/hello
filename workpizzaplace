function UI:UpdateTeleportTween(deltaTime)
    local targetCFrame = self.teleportTweenTarget
    if not targetCFrame then
        return
    end

    local root = self:GetLocalRootPart()
    if not root then
        return
    end

    local rootPosition = root.Position
    local targetPosition = targetCFrame.Position
    local offset = targetPosition - rootPosition
    local distance = offset.Magnitude

    if distance <= 3 then
        pcall(function()
            root.Velocity = Vector3.new(0, 0, 0)
        end)
        root.CFrame = CFrame.new(targetPosition.X, targetPosition.Y, targetPosition.Z)

        local stages = self.teleportTweenStages
        local nextStageIndex = (self.teleportTweenStageIndex or 1) + 1
        if self.teleportTweenUseStages and stages and stages[nextStageIndex] then
            self.teleportTweenStageIndex = nextStageIndex
            self.teleportTweenTarget = stages[nextStageIndex]
        else
            self:ClearActiveTween()
        end
        return
    end

    local stepDistance = self:GetTweenSpeed() * math.max(0, tonumber(deltaTime) or 0)
    if stepDistance <= 0 then
        return
    end

    local nextPosition = targetPosition
    if distance > stepDistance then
        nextPosition = rootPosition + (offset.Unit * stepDistance)
    end

    pcall(function()
        root.Velocity = Vector3.new(0, 0, 0)
    end)
    root.CFrame = CFrame.new(nextPosition.X, nextPosition.Y, nextPosition.Z)
end

