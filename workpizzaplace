    self.teleportTweenUseStages = false
    return true
end

function UI:MoveToCFrame(targetCFrame, useStagedTween)
    if not targetCFrame then
        return false
    end

    if self:GetMovementMode() == "TP" then
        self:ClearActiveTween()
        local root = self:GetLocalRootPart()
        if not root then
            return false
        end
        root.CFrame = targetCFrame
        return true
    end

    if useStagedTween then
        return self:StartTweenToCFrame(targetCFrame)
    end

    return self:StartDirectTweenToCFrame(targetCFrame)
end

